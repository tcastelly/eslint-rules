{
  "compilerOptions": {
    "types": ["node"],
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "emitDeclarationOnly": true,
    "module": "nodenext",
    "allowJs": true,
    "checkJs": true,
    "target": "esnext",
    "lib": ["es2016", "dom"],
    "noImplicitAny": false,
    "allowSyntheticDefaultImports": true
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
